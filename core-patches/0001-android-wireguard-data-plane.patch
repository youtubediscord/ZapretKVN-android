diff --git a/transport/wireguard/android_engine.go b/transport/wireguard/android_engine.go
new file mode 100644
index 00000000..6c5d0f5a
--- /dev/null
+++ b/transport/wireguard/android_engine.go
@@ -0,0 +1,73 @@
+package wireguard
+
+import (
+	"sync"
+
+	"github.com/metacubex/amneziawg-go/device"
+	metaConn "github.com/metacubex/wireguard-go/conn"
+	metaDevice "github.com/metacubex/wireguard-go/device"
+	metaTun "github.com/metacubex/wireguard-go/tun"
+	sagerDevice "github.com/sagernet/wireguard-go/device"
+)
+
+// wireGuardEngine is the common lifecycle shared by the pinned sing-box
+// engine and the Android vanilla/Amnezia engines. Keeping it here avoids a
+// second Android TUN or a local proxy hop.
+type wireGuardEngine interface {
+	IpcSet(string) error
+	Up() error
+	Down() error
+	Close()
+	DisableSomeRoamingForBrokenMobileSemantics()
+}
+
+func NewAndroidWireGuardEngine(
+	tunDevice Device,
+	bind metaConn.Bind,
+	logger *sagerDevice.Logger,
+	amnezia *AmneziaOptions,
+	workers int,
+) wireGuardEngine {
+	adapter := newAndroidTunAdapter(tunDevice)
+	metaLogger := &metaDevice.Logger{Verbosef: logger.Verbosef, Errorf: logger.Errorf}
+	if amnezia != nil {
+		engine := device.NewDevice(adapter, bind, metaLogger, workers)
+		engine.DisableSomeRoamingForBrokenMobileSemantics()
+		return &androidWireGuardEngine{wireGuardEngine: engine, tun: adapter}
+	}
+	engine := metaDevice.NewDevice(adapter, bind, metaLogger, workers)
+	engine.DisableSomeRoamingForBrokenMobileSemantics()
+	return &androidWireGuardEngine{wireGuardEngine: engine, tun: adapter}
+}
+
+type androidWireGuardEngine struct {
+	wireGuardEngine
+	tun *androidTunAdapter
+}
+
+func (e *androidWireGuardEngine) activate() {
+	e.tun.events <- metaTun.EventUp
+}
+
+type androidTunAdapter struct {
+	Device
+	events chan metaTun.Event
+	close  sync.Once
+}
+
+func newAndroidTunAdapter(device Device) *androidTunAdapter {
+	return &androidTunAdapter{Device: device, events: make(chan metaTun.Event, 1)}
+}
+
+func (a *androidTunAdapter) Events() <-chan metaTun.Event {
+	return a.events
+}
+
+func (a *androidTunAdapter) Close() error {
+	var err error
+	a.close.Do(func() {
+		close(a.events)
+		err = a.Device.Close()
+	})
+	return err
+}
diff --git a/transport/wireguard/android_client_bind.go b/transport/wireguard/android_client_bind.go
new file mode 100644
index 00000000..6e13be2c
--- /dev/null
+++ b/transport/wireguard/android_client_bind.go
@@ -0,0 +1,179 @@
+package wireguard
+
+import (
+	"context"
+	"net"
+	"net/netip"
+	"sync"
+	"sync/atomic"
+	"time"
+
+	metaConn "github.com/metacubex/wireguard-go/conn"
+	"github.com/sagernet/sing/common/bufio"
+	E "github.com/sagernet/sing/common/exceptions"
+	"github.com/sagernet/sing/common/logger"
+	M "github.com/sagernet/sing/common/metadata"
+	N "github.com/sagernet/sing/common/network"
+)
+
+var _ metaConn.Bind = (*AndroidClientBind)(nil)
+
+// AndroidClientBind always uses the protected sing-box dialer. It avoids the
+// platform UDP batching/GRO path while retaining one Android VpnService TUN.
+type AndroidClientBind struct {
+	ctx         context.Context
+	logger      logger.Logger
+	dialer      N.Dialer
+	bindCtx     context.Context
+	bindDone    context.CancelFunc
+	connAccess  sync.Mutex
+	conn        net.PacketConn
+	closed      atomic.Bool
+	lastLogNano atomic.Int64
+	isConnect   bool
+	connectAddr netip.AddrPort
+}
+
+func NewAndroidClientBind(ctx context.Context, logger logger.Logger, dialer N.Dialer, peers []peerConfig) *AndroidClientBind {
+	bind := &AndroidClientBind{ctx: ctx, logger: logger, dialer: dialer}
+	if len(peers) == 1 && peers[0].endpoint.IsValid() {
+		bind.isConnect = true
+		bind.connectAddr = peers[0].endpoint
+	}
+	return bind
+}
+
+func (b *AndroidClientBind) Open(uint16) ([]metaConn.ReceiveFunc, uint16, error) {
+	b.closed.Store(false)
+	b.bindCtx, b.bindDone = context.WithCancel(b.ctx)
+	return []metaConn.ReceiveFunc{b.receive}, 0, nil
+}
+
+func (b *AndroidClientBind) connect() (net.PacketConn, error) {
+	b.connAccess.Lock()
+	defer b.connAccess.Unlock()
+	if b.closed.Load() {
+		return nil, net.ErrClosed
+	}
+	if b.conn != nil {
+		return b.conn, nil
+	}
+	if b.isConnect {
+		conn, err := b.dialer.DialContext(b.bindCtx, N.NetworkUDP, M.SocksaddrFromNetIP(b.connectAddr))
+		if err != nil {
+			return nil, err
+		}
+		b.conn = bufio.NewUnbindPacketConn(conn)
+	} else {
+		conn, err := b.dialer.ListenPacket(b.bindCtx, M.Socksaddr{Addr: netip.IPv4Unspecified()})
+		if err != nil {
+			return nil, err
+		}
+		b.conn = bufio.NewPacketConn(conn)
+	}
+	return b.conn, nil
+}
+
+func (b *AndroidClientBind) receive(packets [][]byte, sizes []int, endpoints []metaConn.Endpoint) (int, error) {
+	conn, err := b.connect()
+	if err != nil {
+		if b.closed.Load() {
+			return 0, net.ErrClosed
+		}
+		b.logError(E.Cause(err, "connect to wireguard server"))
+		b.waitRetry()
+		return 0, nil
+	}
+	n, address, err := conn.ReadFrom(packets[0])
+	if err != nil {
+		b.dropConn(conn)
+		if b.closed.Load() {
+			return 0, net.ErrClosed
+		}
+		b.logError(E.Cause(err, "read wireguard packet"))
+		b.waitRetry()
+		return 0, nil
+	}
+	sizes[0] = n
+	endpoints[0] = androidEndpoint(M.SocksaddrFromNet(address).Unwrap().AddrPort())
+	return 1, nil
+}
+
+func (b *AndroidClientBind) Close() error {
+	if b.closed.Swap(true) {
+		return nil
+	}
+	if b.bindDone != nil {
+		b.bindDone()
+	}
+	b.connAccess.Lock()
+	defer b.connAccess.Unlock()
+	if b.conn != nil {
+		_ = b.conn.Close()
+		b.conn = nil
+	}
+	return nil
+}
+
+func (b *AndroidClientBind) SetMark(uint32) error { return nil }
+
+func (b *AndroidClientBind) Send(buffers [][]byte, endpoint metaConn.Endpoint) error {
+	conn, err := b.connect()
+	if err != nil {
+		return err
+	}
+	destination := netip.AddrPort(endpoint.(androidEndpoint))
+	for _, buffer := range buffers {
+		if _, err = conn.WriteTo(buffer, net.UDPAddrFromAddrPort(destination)); err != nil {
+			b.dropConn(conn)
+			return err
+		}
+	}
+	return nil
+}
+
+func (b *AndroidClientBind) ParseEndpoint(value string) (metaConn.Endpoint, error) {
+	address, err := netip.ParseAddrPort(value)
+	return androidEndpoint(address), err
+}
+
+func (b *AndroidClientBind) BatchSize() int { return 1 }
+
+func (b *AndroidClientBind) waitRetry() {
+	timer := time.NewTimer(time.Second)
+	defer timer.Stop()
+	select {
+	case <-timer.C:
+	case <-b.bindCtx.Done():
+	}
+}
+
+func (b *AndroidClientBind) logError(err error) {
+	now := time.Now().UnixNano()
+	previous := b.lastLogNano.Load()
+	if now-previous < int64(10*time.Second) || !b.lastLogNano.CompareAndSwap(previous, now) {
+		return
+	}
+	b.logger.Error(err)
+}
+
+func (b *AndroidClientBind) dropConn(conn net.PacketConn) {
+	b.connAccess.Lock()
+	defer b.connAccess.Unlock()
+	if b.conn == conn {
+		_ = b.conn.Close()
+		b.conn = nil
+	}
+}
+
+type androidEndpoint netip.AddrPort
+
+func (e androidEndpoint) ClearSrc()           {}
+func (e androidEndpoint) SrcToString() string { return "" }
+func (e androidEndpoint) DstToString() string { return netip.AddrPort(e).String() }
+func (e androidEndpoint) DstToBytes() []byte {
+	value, _ := netip.AddrPort(e).MarshalBinary()
+	return value
+}
+func (e androidEndpoint) DstIP() netip.Addr { return netip.AddrPort(e).Addr() }
+func (e androidEndpoint) SrcIP() netip.Addr { return netip.Addr{} }
