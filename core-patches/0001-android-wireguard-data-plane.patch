@@ -0,0 +1,130 @@
+package wireguard
+
+import (
+	"context"
+	"io"
+	"net"
+	"net/netip"
+	"testing"
+	"time"
+
+	metaConn "github.com/metacubex/wireguard-go/conn"
+	metaTun "github.com/metacubex/wireguard-go/tun"
+	"github.com/sagernet/sing/common/logger"
+	M "github.com/sagernet/sing/common/metadata"
+
+	"github.com/stretchr/testify/require"
+)
+
+func TestAndroidClientBindConnectedRoundTrip(t *testing.T) {
+	connection := newTestPacketConnection()
+	bind := NewAndroidClientBind(
+		context.Background(),
+		logger.NOP(),
+		testDialer{connection: connection},
+		[]peerConfig{{endpoint: netip.MustParseAddrPort("192.0.2.1:51820")}},
+	)
+	receivers, _, err := bind.Open(0)
+	require.NoError(t, err)
+	require.Equal(t, 1, bind.BatchSize())
+
+	endpoint, err := bind.ParseEndpoint("192.0.2.1:51820")
+	require.NoError(t, err)
+	require.NoError(t, bind.Send([][]byte{[]byte("outbound")}, endpoint))
+	require.Equal(t, []byte("outbound"), <-connection.writes)
+
+	connection.reads <- []byte("inbound")
+	packets := [][]byte{make([]byte, 64)}
+	sizes := make([]int, 1)
+	endpoints := make([]metaConn.Endpoint, 1)
+	count, err := receivers[0](packets, sizes, endpoints)
+	require.NoError(t, err)
+	require.Equal(t, 1, count)
+	require.Equal(t, []byte("inbound"), packets[0][:sizes[0]])
+	require.Equal(t, "192.0.2.1:51820", endpoints[0].DstToString())
+	require.NoError(t, bind.Close())
+	require.NoError(t, bind.Close())
+}
+
+func TestAndroidWireGuardEngineActivatesTunExplicitly(t *testing.T) {
+	tun := &androidTunAdapter{events: make(chan metaTun.Event, 1)}
+	engine := &androidWireGuardEngine{wireGuardEngine: testWireGuardEngine{}, tun: tun}
+	select {
+	case <-tun.events:
+		t.Fatal("TUN became active before IPC configuration")
+	default:
+	}
+	engine.activate()
+	require.Equal(t, metaTun.Event(metaTun.EventUp), <-tun.events)
+}
+
+type testWireGuardEngine struct{}
+
+func (testWireGuardEngine) IpcSet(string) error                         { return nil }
+func (testWireGuardEngine) Up() error                                   { return nil }
+func (testWireGuardEngine) Down() error                                 { return nil }
+func (testWireGuardEngine) Close()                                      {}
+func (testWireGuardEngine) DisableSomeRoamingForBrokenMobileSemantics() {}
+
+type testDialer struct{ connection net.Conn }
+
+func (d testDialer) DialContext(context.Context, string, M.Socksaddr) (net.Conn, error) {
+	return d.connection, nil
+}
+
+func (d testDialer) ListenPacket(context.Context, M.Socksaddr) (net.PacketConn, error) {
+	return nil, io.ErrUnexpectedEOF
+}
+
+type testPacketConnection struct {
+	reads  chan []byte
+	writes chan []byte
+	closed chan struct{}
+}
+
+func newTestPacketConnection() *testPacketConnection {
+	return &testPacketConnection{
+		reads:  make(chan []byte, 1),
+		writes: make(chan []byte, 1),
+		closed: make(chan struct{}),
+	}
+}
+
+func (c *testPacketConnection) Read(buffer []byte) (int, error) {
+	select {
+	case packet := <-c.reads:
+		return copy(buffer, packet), nil
+	case <-c.closed:
+		return 0, net.ErrClosed
+	}
+}
+
+func (c *testPacketConnection) Write(buffer []byte) (int, error) {
+	copyBuffer := append([]byte(nil), buffer...)
+	select {
+	case c.writes <- copyBuffer:
+		return len(buffer), nil
+	case <-c.closed:
+		return 0, net.ErrClosed
+	}
+}
+
+func (c *testPacketConnection) Close() error {
+	select {
+	case <-c.closed:
+	default:
+		close(c.closed)
+	}
+	return nil
+}
+
+func (c *testPacketConnection) LocalAddr() net.Addr              { return testAddress("192.0.2.2:12345") }
+func (c *testPacketConnection) RemoteAddr() net.Addr             { return testAddress("192.0.2.1:51820") }
+func (c *testPacketConnection) SetDeadline(time.Time) error      { return nil }
+func (c *testPacketConnection) SetReadDeadline(time.Time) error  { return nil }
+func (c *testPacketConnection) SetWriteDeadline(time.Time) error { return nil }
+
+type testAddress string
